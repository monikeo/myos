# ============================================================
# MyOS — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Gemini AI ---
GEMINI_API_KEY="your_gemini_api_key_here"

# --- App ---
APP_URL="http://localhost:3000"
NODE_ENV="development"

# --- Supabase (Primary Database) ---
# From: supabase.com → your project → Settings → API
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your_supabase_anon_key_here"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"   # backend only — never expose to client

# --- Google Service Account ---
# From: console.cloud.google.com → IAM → Service Accounts → Create → Download JSON
# Enable: Google Sheets API + Google Drive API
# Share your Sheet + Drive folder to this email as Editor
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@your-project-id.iam.gserviceaccount.com"
# Paste the private_key from the JSON (keep the newlines as \n)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_service_key_goes_here\n-----END PRIVATE KEY-----\n"

# --- Google Sheets Backup ---
# Sheet URL: https://docs.google.com/spreadsheets/d/[SHEET_ID]/edit
# Share to service account email with Editor access
GOOGLE_SHEET_ID="your_google_sheet_id_here"

# --- Google Drive Storage ---
# Folder URL: https://drive.google.com/drive/folders/[FOLDER_ID]
# Share to service account email with Editor access
GOOGLE_DRIVE_FOLDER_ID="your_google_drive_folder_id_here"
